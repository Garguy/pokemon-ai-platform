type Query {
    ping: String!
    me: User
}

type Mutation {
    register(input: RegisterInput!): AuthPayload!
    login(input: LoginInput!): AuthPayload!
}

type User {
    id: ID!
    email: String!
    createdAt: String!
}

type AuthPayload {
    token: String!
    user: User!
}

input RegisterInput {
    email: String!
    password: String!
}

input LoginInput {
    email: String!
    password: String!
}
